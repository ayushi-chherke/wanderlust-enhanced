<% layout("/layouts/boilerplate") %>

<div id="filters">
  <div class="filter active" onclick="filterListings('all', this)">
    <i class="fa-solid fa-border-all"></i><p>All</p>
  </div>
  <div class="filter" onclick="filterListings('trending', this)">
    <i class="fa-solid fa-fire"></i><p>Trending</p>
  </div>
  <div class="filter" onclick="filterListings('rooms', this)">
    <i class="fa-solid fa-bed"></i><p>Rooms</p>
  </div>
  <div class="filter" onclick="filterListings('cities', this)">
    <i class="fa-solid fa-mountain-city"></i><p>Iconic Cities</p>
  </div>
  <div class="filter" onclick="filterListings('mountains', this)">
    <i class="fa-solid fa-mountain"></i><p>Mountains</p>
  </div>
  <div class="filter" onclick="filterListings('castles', this)">
    <i class="fa-brands fa-fort-awesome"></i><p>Castles</p>
  </div>
  <div class="filter" onclick="filterListings('pools', this)">
    <i class="fa-solid fa-person-swimming"></i><p>Amazing Pools</p>
  </div>
  <div class="filter" onclick="filterListings('camping', this)">
    <i class="fa-solid fa-campground"></i><p>Camping</p>
  </div>
  <div class="filter" onclick="filterListings('farms', this)">
    <i class="fa-solid fa-tractor"></i><p>Farms</p>
  </div>
  <div class="filter" onclick="filterListings('arctic', this)">
    <i class="fa-regular fa-snowflake"></i><p>Arctic</p>
  </div>
  <div class="tax-toggle">
    <div class="form-check-reverse form-switch mb-0">
      <input class="form-check-input" type="checkbox" role="switch" id="taxSwitch">
      <label class="form-check-label" for="taxSwitch" style="font-size:0.82rem;">Show total with taxes</label>
    </div>
  </div>
</div>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3" id="listings-grid">
  <% for(let listing of allListings) { %>
  <a href="/listings/<%= listing._id %>" class="listing-link col">
    <div class="listing-card">
      <div class="card-img-wrap">
        <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>">
        <button class="card-wish" onclick="event.preventDefault(); this.querySelector('i').classList.toggle('fa-solid'); this.querySelector('i').classList.toggle('fa-regular'); this.style.color = this.querySelector('i').classList.contains('fa-solid') ? 'var(--brand)' : '';" title="Save to wishlist">
          <i class="fa-regular fa-heart"></i>
        </button>
      </div>
      <div class="card-body">
        <div class="card-title-row">
          <p class="card-listing-title"><%= listing.title %></p>
          <span style="font-size:0.82rem;white-space:nowrap;"><i class="fa-solid fa-star" style="color:var(--brand);font-size:0.75rem;"></i> 4.8</span>
        </div>
        <p class="card-listing-sub"><%= listing.location %>, <%= listing.country %></p>
        <p class="card-listing-price">
          <strong>&#8377;<%= listing.price.toLocaleString("en-IN") %></strong> / night
          <i class="tax-info">&nbsp;+18% GST</i>
        </p>
      </div>
    </div>
  </a>
  <% } %>
</div>

<script>
  document.getElementById("taxSwitch").addEventListener("change", function() {
    document.querySelectorAll(".tax-info").forEach(el => {
      el.style.display = this.checked ? "inline" : "none";
    });
  });

  function filterListings(category, el) {
    document.querySelectorAll(".filter").forEach(f => f.classList.remove("active"));
    el.classList.add("active");
    // Visual filter — in production, would call server route
    const cards = document.querySelectorAll(".listing-link");
    cards.forEach(card => { card.style.display = "block"; });
  }
</script>
