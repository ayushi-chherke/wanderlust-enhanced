<% layout("/layouts/boilerplate") %>
<div class="form-page-wrap" style="max-width:640px;">
  <h3>Create a New Listing</h3>
  <form action="/listings" method="POST" class="needs-validation" novalidate enctype="multipart/form-data">
    <div class="mb-3">
      <label class="form-label" style="font-size:0.85rem;font-weight:600;">Title</label>
      <input name="listing[title]" type="text" class="form-control" placeholder="Add a catchy title" required>
      <div class="valid-feedback">Title looks good!</div>
    </div>
    <div class="mb-3">
      <label class="form-label" style="font-size:0.85rem;font-weight:600;">Description</label>
      <textarea name="listing[description]" class="form-control" rows="4" placeholder="Describe your space..." required></textarea>
      <div class="invalid-feedback">Please enter a short description</div>
    </div>
    <div class="mb-3">
      <label class="form-label" style="font-size:0.85rem;font-weight:600;">Listing Image</label>
      <input name="listing[image]" type="file" class="form-control" required>
    </div>
    <div class="row g-3 mb-3">
      <div class="col-md-5">
        <label class="form-label" style="font-size:0.85rem;font-weight:600;">Price per night (₹)</label>
        <input name="listing[price]" type="number" placeholder="1200" class="form-control" required>
        <div class="invalid-feedback">Price should be valid</div>
      </div>
      <div class="col-md-7">
        <label class="form-label" style="font-size:0.85rem;font-weight:600;">Country</label>
        <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
        <div class="invalid-feedback">Country name should be valid</div>
      </div>
    </div>
    <div class="mb-4">
      <label class="form-label" style="font-size:0.85rem;font-weight:600;">Location</label>
      <input name="listing[location]" placeholder="Jaipur, Rajasthan" type="text" class="form-control" required>
      <div class="invalid-feedback">Location should be valid</div>
    </div>
    <button class="btn-brand-submit" type="submit">
      <i class="fa-solid fa-plus" style="margin-right:0.4rem;"></i> Add Listing
    </button>
  </form>
</div>
